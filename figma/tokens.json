{
  "color": {
    "bg": {
      "$value": "#f6f6f4",
      "$type": "color",
      "$description": "Page background"
    },
    "surface": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Card / nav surface"
    },
    "text": {
      "$value": "#141414",
      "$type": "color",
      "$description": "Primary text"
    },
    "muted": {
      "$value": "#6c6c6c",
      "$type": "color",
      "$description": "Secondary / label text"
    },
    "rule": {
      "$value": "#ddddd8",
      "$type": "color",
      "$description": "Divider lines"
    },
    "accent": {
      "$value": "#0047b3",
      "$type": "color",
      "$description": "Brand blue — links, highlights, CTAs"
    },
    "accentLight": {
      "$value": "#e8effa",
      "$type": "color",
      "$description": "Soft accent tint for tags"
    },
    "accentHover": {
      "$value": "#003899",
      "$type": "color",
      "$description": "Darker accent for hover state"
    },
    "availGreen": {
      "$value": "#5eead4",
      "$type": "color",
      "$description": "Availability pulse indicator"
    },
    "contactGreen": {
      "$value": "#2a7a2a",
      "$type": "color",
      "$description": "Open-to-work indicator in contact"
    }
  },
  "dimension": {
    "labelWidth": {
      "$value": "180px",
      "$type": "dimension",
      "$description": "Two-column layout: label column width"
    },
    "navHeight": {
      "$value": "56px",
      "$type": "dimension",
      "$description": "Sticky nav bar height"
    },
    "pageMaxWidth": {
      "$value": "1180px",
      "$type": "dimension",
      "$description": "Max content width"
    },
    "sectionPaddingV": {
      "$value": "88px",
      "$type": "dimension",
      "$description": "Vertical section padding (5.5rem)"
    },
    "columnGap": {
      "$value": "72px",
      "$type": "dimension",
      "$description": "Gap between label and content columns (4.5rem)"
    }
  },
  "typography": {
    "fontFamily": {
      "$value": "Inter",
      "$type": "fontFamily"
    },
    "baseFontSize": {
      "$value": "15px",
      "$type": "dimension"
    },
    "heroName": {
      "$value": {
        "fontFamily": "Inter",
        "fontWeight": 800,
        "fontSize": "112px",
        "letterSpacing": "-0.04em",
        "lineHeight": "0.95"
      },
      "$type": "typography",
      "$description": "Hero large name — clamp(3.25rem, 8vw, 7rem)"
    },
    "navLogo": {
      "$value": {
        "fontFamily": "Inter",
        "fontWeight": 700,
        "fontSize": "12.8px",
        "letterSpacing": "0.06em",
        "textTransform": "UPPERCASE"
      },
      "$type": "typography"
    },
    "navLink": {
      "$value": {
        "fontFamily": "Inter",
        "fontWeight": 500,
        "fontSize": "12px",
        "letterSpacing": "0.04em",
        "textTransform": "UPPERCASE"
      },
      "$type": "typography"
    },
    "sectionLabel": {
      "$value": {
        "fontFamily": "Inter",
        "fontWeight": 700,
        "fontSize": "10.88px",
        "letterSpacing": "0.14em",
        "textTransform": "UPPERCASE"
      },
      "$type": "typography"
    },
    "bodyText": {
      "$value": {
        "fontFamily": "Inter",
        "fontWeight": 400,
        "fontSize": "15px",
        "lineHeight": "1.85"
      },
      "$type": "typography"
    },
    "statNumber": {
      "$value": {
        "fontFamily": "Inter",
        "fontWeight": 800,
        "fontSize": "40px",
        "letterSpacing": "-0.04em",
        "lineHeight": "1"
      },
      "$type": "typography"
    },
    "button": {
      "$value": {
        "fontFamily": "Inter",
        "fontWeight": 700,
        "fontSize": "11.52px",
        "letterSpacing": "0.07em",
        "textTransform": "UPPERCASE"
      },
      "$type": "typography"
    },
    "expPeriod": {
      "$value": {
        "fontFamily": "monospace",
        "fontWeight": 400,
        "fontSize": "11.52px"
      },
      "$type": "typography"
    }
  },
  "border": {
    "rule": {
      "$value": {
        "color": "#ddddd8",
        "width": "1px",
        "style": "solid"
      },
      "$type": "border"
    },
    "ruleStrong": {
      "$value": {
        "color": "#141414",
        "width": "2px",
        "style": "solid"
      },
      "$type": "border",
      "$description": "Used for contact section top border"
    },
    "heroSeparator": {
      "$value": {
        "color": "rgba(255,255,255,0.25)",
        "width": "1px",
        "style": "solid"
      },
      "$type": "border"
    }
  }
}
